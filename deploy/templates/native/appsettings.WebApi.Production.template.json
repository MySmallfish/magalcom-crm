{
  "AllowedHosts": "*",
  "Authentication": {
    "Entra": {
      "TenantId": "__ENTRA_TENANT_ID__",
      "ApiClientId": "__ENTRA_API_CLIENT_ID__",
      "Audience": "api://__ENTRA_API_CLIENT_ID__"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "__PUBLIC_WEBAPP_URL__"
    ]
  },
  "Features": {
    "MiniAppsExternalOrigins": false,
    "BiChatScaffold": true
  },
  "Shell": {
    "Navigation": {
      "Items": []
    }
  },
  "MiniApps": {
    "Items": []
  },
  "ServiceBus": {
    "ConnectionString": "__SERVICEBUS_CONNECTION_STRING__",
    "CommandTopic": "crm.commands",
    "EventTopic": "crm.events",
    "JobsQueue": "crm.jobs"
  },
  "DataAccess": {
    "Provider": "SqlServer",
    "ConnectionString": "__SQL_CONNECTION_STRING__"
  }
}
