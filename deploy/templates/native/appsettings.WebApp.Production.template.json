{
  "AllowedHosts": "*",
  "Shell": {
    "ApiBaseUrl": "__PUBLIC_WEBAPI_URL__",
    "Authentication": {
      "Mode": "entra",
      "Entra": {
        "TenantId": "__ENTRA_TENANT_ID__",
        "SpaClientId": "__ENTRA_SPA_CLIENT_ID__",
        "Scope": "api://__ENTRA_API_CLIENT_ID__/access_as_user",
        "RedirectUri": "__PUBLIC_WEBAPP_URL__/",
        "PostLogoutRedirectUri": "__PUBLIC_WEBAPP_URL__/"
      }
    }
  },
  "Features": {
    "MiniAppsExternalOrigins": false,
    "BiChatScaffold": true
  },
  "MiniApps": {
    "AllowedOrigins": [
      "__PUBLIC_WEBAPP_URL__"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
