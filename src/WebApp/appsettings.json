{
  "AllowedHosts": "*",
  "Shell": {
    "ApiBaseUrl": "http://localhost:7002",
    "Authentication": {
      "Mode": "msal",
      "DisableAuthentication": true,
      "Entra": {
        "TenantId": "",
        "SpaClientId": "",
        "Scope": "api://your-api-client-id/.default"
      }
    }
  },
  "Features": {
    "LeadsModule": true,
    "MiniAppsExternalOrigins": false,
    "BiChatScaffold": true
  },
  "MiniApps": {
    "AllowedOrigins": [
      "http://localhost:7001"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
